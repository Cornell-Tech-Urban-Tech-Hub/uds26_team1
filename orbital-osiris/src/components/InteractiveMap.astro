<script>
  const setupMap = () => {
    // ── Tab switching ──
    const buttons = document.querySelectorAll('.map-btn');
    const layers = document.querySelectorAll('.map-layer');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => b.classList.remove('active'));
        layers.forEach(l => l.classList.remove('active'));
        btn.classList.add('active');
        const targetId = `map-${(btn as HTMLElement).dataset.target}`;
        document.getElementById(targetId)?.classList.add('active');
      });
    });

    // ── SVG glow ──
    const svg = document.getElementById('spine-svg') as any;
    const glowCircle = document.getElementById('glow-circle');
    if (svg && glowCircle) {
      svg.addEventListener('mousemove', (e: MouseEvent) => {
        const pt = svg.createSVGPoint();
        pt.x = e.clientX;
        pt.y = e.clientY;
        const svgP = pt.matrixTransform(svg.getScreenCTM().inverse());
        glowCircle.setAttribute('cx', svgP.x.toString());
        glowCircle.setAttribute('cy', svgP.y.toString());
      });
      svg.addEventListener('mouseleave', () => {
        glowCircle.setAttribute('cx', '-1000');
        glowCircle.setAttribute('cy', '-1000');
      });
    }

    // ── Simulation carousel ──
    const slides = document.getElementById('sim-slides') as HTMLElement;
    const dots = document.querySelectorAll('.sim-dot');
    const prevBtn = document.getElementById('sim-prev');
    const nextBtn = document.getElementById('sim-next');
    const total = document.querySelectorAll('.sim-slide').length; // 4
    let current = 0;

    const goTo = (index: number) => {
      current = (index + total) % total;
      slides.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => d.classList.toggle('active', i === current));
    };

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

    // Keyboard navigation when sim tab is active
    document.addEventListener('keydown', (e) => {
      const simLayer = document.getElementById('map-sim');
      if (!simLayer?.classList.contains('active')) return;
      if (e.key === 'ArrowRight') goTo(current + 1);
      if (e.key === 'ArrowLeft') goTo(current - 1);
    });

    // Touch / swipe
    let touchStartX = 0;
    slides?.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    slides?.addEventListener('touchend', (e: TouchEvent) => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) goTo(diff > 0 ? current + 1 : current - 1);
    }, { passive: true });
  };

  document.addEventListener('DOMContentLoaded', setupMap);
</script>