---
// InteractiveMap.astro
---

<div class="map-container sharp-border interactive-hover">
  <div class="map-header">
    <h3><span class="marker-highlight">Prediction</span>: The Art Spine & Congestion Relief</h3>
    <div class="map-controls">
      <button class="map-btn active" data-target="path">The Path</button>
      <button class="map-btn" data-target="sim">Simulation Data</button>
      <button class="map-btn" data-target="congestion">Congestion Relief</button>
      
    </div>
  </div>

  <div class="map-display">
    <div id="map-path" class="map-layer interactive-path-layer active">
      <div class="path-legend sharp-border interactive-hover">
        <h4>Art Spine Anchors</h4>
        <div class="legend-item">
          <span class="color-swatch" style="background-color: #fceb55;"></span>
          <div class="legend-text">
            <strong>Hey Clay Pottery Studio</strong>
            <p>Emphasis on shared resources and knowledge</p>
          </div>
        </div>
        <div class="legend-item">
          <span class="color-swatch" style="background-color: #7d4cf6;"></span>
          <div class="legend-text">
            <strong>Textile Arts Center</strong>
            <p>Exhibits, summer camps, and galleries</p>
          </div>
        </div>
        <div class="legend-item">
          <span class="color-swatch" style="background-color: #f68c34;"></span>
          <div class="legend-text">
            <strong>Theater Mitu (Mitu580)</strong>
            <p>Combination of niche and common plays, small business and research</p>
          </div>
        </div>
        <div class="legend-item">
          <span class="color-swatch" style="background-color: #c0f696;"></span>
          <div class="legend-text">
            <strong>ZeroSpace</strong>
            <p>Modern, digital and live theater</p>
          </div>
        </div>
      </div>
      
      <div class="map-wrapper">
        <img src={`${import.meta.env.BASE_URL}/images/map.png`} alt="Base Map" class="base-map-img" />
        <svg class="path-svg" viewBox="0 0 1408 1612" preserveAspectRatio="xMidYMid meet" id="spine-svg">
          <defs>
            <path id="spine-path" d="M 712 826 L 905 837 L 905 671 L 707 655 L 707 342 L 905 336" fill="none" stroke-width="36" stroke-linecap="round" stroke-linejoin="round" />
            <mask id="glow-mask">
              <rect width="100%" height="100%" fill="black" />
              <circle id="glow-circle" cx="-1000" cy="-1000" r="225" fill="url(#glow-gradient)" />
            </mask>
            <radialGradient id="glow-gradient">
              <stop offset="0%" stop-color="white" />
              <stop offset="50%" stop-color="rgba(255,255,255,0.5)" />
              <stop offset="100%" stop-color="black" />
            </radialGradient>
          </defs>
          <use href="#spine-path" stroke="rgba(255, 51, 102, 0.3)" />
          <use href="#spine-path" stroke="var(--color-secondary)" class="animated-path" mask="url(#glow-mask)" />
        </svg>
      </div>
    </div>
    
    <!-- ── SIMULATION CAROUSEL ── -->
    <div id="map-sim" class="map-layer sim-carousel-layer">
      <div class="sim-carousel">
        <div class="sim-slides" id="sim-slides">

          <!-- Slide 1: Baseline vs Intervention -->
          <div class="sim-slide">
            <div class="sim-media">
              <!--
                To use a .mov video, replace <img> with:
                <video controls playsinline muted loop>
                  <source src={`${import.meta.env.BASE_URL}/videos/sim-1.mov`} type="video/quicktime" />
                  <source src={`${import.meta.env.BASE_URL}/videos/sim-1.mp4`} type="video/mp4" />
                </video>
              -->
              <img src={`${import.meta.env.BASE_URL}/images/sim-1.png`} alt="Simulation 1: Baseline vs Intervention" />
            </div>
            <div class="sim-info">
              <div class="sim-index-label">Escenario 01 / 04</div>
              <div class="sim-scenario-tag">Baseline vs Intervention</div>
              <h4>Baseline vs Intervention</h4>
              <div class="sim-finding-block">
                <div class="sim-field">
                  <span class="sim-field-label">Hypothesis</span>
                  <p>A curated path turns accidental discovery into intentional engagement.</p>
                </div>
                <div class="sim-field">
                  <span class="sim-field-label">From our simulation</span>
                  <p>55 vs. 40 studio visits at cycle 350 — a <strong>38% increase</strong>.</p>
                </div>
                <div class="sim-field finding">
                  <span class="sim-field-label">Finding</span>
                  <p>Even under conservative assumptions, the Arts Spine generates <strong>38% more studio visits</strong> than no intervention.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Slide 2: Studio Density / Placement -->
          <div class="sim-slide">
            <div class="sim-media">
              <!--
                <video controls playsinline muted loop>
                  <source src={`${import.meta.env.BASE_URL}/videos/sim-2.mov`} type="video/quicktime" />
                  <source src={`${import.meta.env.BASE_URL}/videos/sim-2.mp4`} type="video/mp4" />
                </video>
              -->
              <img src={`${import.meta.env.BASE_URL}/images/sim-2.png`} alt="Simulation 2: Studio Density & Placement" />
            </div>
            <div class="sim-info">
              <div class="sim-index-label">Escenario 02 / 04</div>
              <div class="sim-scenario-tag">Studio Density / Placement</div>
              <h4>Density & Placement</h4>
              <div class="sim-finding-block">
                <div class="sim-field">
                  <span class="sim-field-label">Hypothesis</span>
                  <p>A longer spine reaches more studios but may dilute engagement. A shorter, denser route could drive deeper visits within a cluster.</p>
                </div>
                <div class="sim-field finding">
                  <span class="sim-field-label">Simulation Finding</span>
                  <p>The shorter spine still drives significantly more visits than the baseline. <strong>Starting small</strong>, measuring impact, and expanding later may be the smarter path forward.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Slide 3: Signage / Wayfinding Awareness -->
          <div class="sim-slide">
            <div class="sim-media sim-media-duo">
              <!--
                Replace <img> tags with <video> blocks for .mov support:
                <video controls playsinline muted loop>
                  <source src={`${import.meta.env.BASE_URL}/videos/sim-3a.mov`} type="video/quicktime" />
                  <source src={`${import.meta.env.BASE_URL}/videos/sim-3a.mp4`} type="video/mp4" />
                </video>
              -->
              <div class="media-duo-item">
                <video autoplay playsinline muted loop>
                  <source src={`${import.meta.env.BASE_URL}/videos/Access_10_.mp4`} type="video/mp4" />
                </video>
                <span class="media-duo-label">Low Awareness</span>
              </div>
              <div class="media-duo-item">
                <video autoplay playsinline muted loop>
                  <source src={`${import.meta.env.BASE_URL}/videos/Access_75_.mp4`} type="video/mp4" />
                </video>
                <span class="media-duo-label">High Awareness</span>
              </div>
            </div>
            <div class="sim-info">
              <div class="sim-index-label">Escenario 03 / 04</div>
              <div class="sim-scenario-tag">Signage / Wayfinding Awareness</div>
              <h4>Signage & Wayfinding</h4>
              <div class="sim-finding-block">
                <div class="sim-field">
                  <span class="sim-field-label">Hypothesis</span>
                  <p>Better wayfinding and signage investment increases pedestrians who actively engage with the spine. Higher spend → + awareness → + visits.</p>
                </div>
                <div class="sim-field finding">
                  <span class="sim-field-label">Simulation Finding</span>
                  <p>Adjusting awareness from low to high produces a visible increase in active pedestrian flow. Stakeholders have a <strong>tunable lever</strong> to model different investment scenarios.</p>
                </div>
                <div class="sim-field source-field">
                  <span class="sim-field-label">Source</span>
                  <p><a href="https://doi.org/10.1016/j.ssci.2021.105440" target="_blank" rel="noopener">Wayfinding Signage and Walking Perception in Urban Environments</a></p>
                </div>
              </div>
            </div>
          </div>

          <!-- Slide 4: Art Spine + Footprint (MTA Commuters) -->
          <div class="sim-slide">
            <div class="sim-media">
              <!--
                <video controls playsinline muted loop>
                  <source src={`${import.meta.env.BASE_URL}/videos/sim-4.mov`} type="video/quicktime" />
                  <source src={`${import.meta.env.BASE_URL}/videos/sim-4.mp4`} type="video/mp4" />
                </video>
              -->
              <video autoplay playsinline muted loop>
                <source src={`${import.meta.env.BASE_URL}/videos/trimmed_spine_.mp4`} type="video/mp4" />
              </video>
            </div>
            <div class="sim-info">
              <div class="sim-index-label">Escenario 04 / 04</div>
              <div class="sim-scenario-tag mta-tag">MTA — Pedestrian Origin Points</div>
              <h4>Art Spine + Footprint</h4>
              <div class="sim-finding-block">
                <div class="sim-field">
                  <span class="sim-field-label">Hypothesis</span>
                  <p>Commuters from subway stations will increase foot traffic and engagement of the Art Spine.</p>
                </div>
                <div class="sim-field finding">
                  <span class="sim-field-label">Simulation Finding</span>
                  <ul class="sim-bullets">
                    <li><strong>Blue line:</strong> Unique commuters entering the area — eventually plateaus ± a negligible number each week.</li>
                    <li><strong>Pink line:</strong> How commuters engage with the Art Spine over time.</li>
                  </ul>
                  <p>Shows a pragmatic but tangible amount of foot traffic the Art Spine will continue to receive.</p>
                </div>
              </div>
            </div>
          </div>

        </div><!-- /sim-slides -->
      </div><!-- /sim-carousel -->

      <!-- Nav controls -->
      <div class="sim-nav">
        <button class="sim-nav-btn" id="sim-prev" aria-label="Previous simulation">&#8592;</button>
        <div class="sim-dots" id="sim-dots">
          <span class="sim-dot active"></span>
          <span class="sim-dot"></span>
          <span class="sim-dot"></span>
          <span class="sim-dot"></span>
        </div>
        <button class="sim-nav-btn" id="sim-next" aria-label="Next simulation">&#8594;</button>
      </div>
    </div><!-- /map-sim -->

    <div id="map-congestion" class="map-layer congestion-layer">
      <div class="cong-hero">
        <img src={`${import.meta.env.BASE_URL}/images/congestion-hero2.png`} alt="New development in Gowanus" class="cong-hero-img" />
        <div class="cong-hero-overlay">
          <p class="cong-hero-text">New Neighbor <span>"Congestion Relief"</span>-Style Pricing</p>
        </div>
      </div>

      <div class="cong-body">

        <div class="cong-intro">
          <p>As Gowanus grows, new luxury residents benefit from the neighborhood's culture — built by artists over decades. The <strong>Congestion Relief Fee</strong> asks newcomers to invest in preserving what made them want to move here.</p>
        </div>

        <div class="cong-stats">
          <div class="c-stat">
            <div class="c-num">5,300+</div>
            <div class="c-label">New units filed since the 2021 rezoning</div>
          </div>
          <div class="c-stat">
            <div class="c-num">2.3</div>
            <div class="c-label">Average people per household in NYC (Census)</div>
          </div>
          <div class="c-stat highlight">
            <div class="c-num">~12,000</div>
            <div class="c-label">New renters projected to arrive in Gowanus</div>
          </div>
          <div class="c-stat highlight">
            <div class="c-num">$2.4M</div>
            <div class="c-label">Potential fund at $200/person one-time fee</div>
          </div>
        </div>

        <div class="cong-flow">
          <div class="cong-step">
            <div class="cong-num">01</div>
            <p>New resident moves into a luxury development in the Congestion Relief Zone</p>
          </div>
          <div class="cong-arrow">→</div>
          <div class="cong-step">
            <div class="cong-num">02</div>
            <p>Pays a one-time fee at closing or lease signing</p>
          </div>
          <div class="cong-arrow">→</div>
          <div class="cong-step">
            <div class="cong-num">03</div>
            <p>Funds go directly into the Art Spine Fund for studio preservation and streetscaping</p>
          </div>
        </div>

        <div class="cong-why">
          <div class="cong-why-item">
            <span class="cx">✗</span>
            <p><strong>Not a tax.</strong> A community contribution built into the purchase and rental process — no complicated extra process to receive funds.</p>
          </div>
          <div class="cong-why-item">
            <span class="ck">✓</span>
            <p><strong>Community-controlled.</strong> A resident board — majority artists and long-term Gowanus members — decides how funds are spent.</p>
          </div>
          <div class="cong-why-item">
            <span class="cx">✗</span>
            <p><strong>Not displacement.</strong> Unlike the High Line, the Art Spine uses development pressure to fund artist retention.</p>
          </div>
          <div class="cong-why-item">
            <span class="ck">✓</span>
            <p><strong>Scalable.</strong> As more developments come online, the fund grows automatically without burdening existing residents.</p>
          </div>
        </div>

      </div>
    </div>

   
  </div>
</div>

<style>
  .map-container {
    background-color: var(--color-dark);
    color: var(--color-bg);
    padding: 3rem 2rem;
    margin: 3rem 0;
    transform: rotate(1deg);
  }
  
  .map-header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .map-header h3 { margin: 0; color: var(--color-bg); }
  .map-controls { display: flex; gap: 1rem; flex-wrap: wrap; }

  .map-btn {
    background: transparent;
    border: 3px solid var(--color-bg);
    color: var(--color-bg);
    padding: 0.5rem 1rem;
    font-family: var(--font-heading);
    cursor: pointer;
    text-transform: uppercase;
    transition: all 0.2s ease;
  }

  .map-btn:hover, .map-btn.active {
    background: var(--color-accent);
    color: var(--color-text);
    border-color: var(--color-accent);
    transform: translate(-4px, -4px);
    box-shadow: 4px 4px 0px var(--color-bg);
  }

  .map-display {
    position: relative;
    width: 100%;
    min-height: 500px;
    background: #222;
    overflow-y: auto;
    border: 3px solid var(--color-bg);
  }

  .map-layer {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    object-fit: contain;
    opacity: 0;
    transform: scale(0.98);
    transition: opacity 0.4s ease, transform 0.4s ease;
    pointer-events: none;
  }

  .map-layer.active {
    opacity: 1;
    transform: scale(1);
    pointer-events: auto;
  }

  /* ── SIMULATION CAROUSEL ── */
  .sim-carousel-layer {
    display: flex;
    flex-direction: column;
    background: var(--color-dark);
    overflow: hidden;
  }

  .sim-carousel { flex: 1; overflow: hidden; position: relative; }

  .sim-slides {
    display: flex;
    height: 100%;
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  .sim-slide {
    min-width: 100%;
    height: 100%;
    display: flex;
    flex-direction: row;
    align-items: stretch;
    overflow: hidden;
  }

  .sim-media {
    flex: 1.5;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #111;
    overflow: hidden;
    border-right: 3px solid var(--color-accent);
  }

  .sim-media img,
  .sim-media video {
    width: 100%; height: 100%;
    object-fit: cover;
    border: none; box-shadow: none;
    display: block;
  }

  /* Side-by-side media for Scenario 3 */
  .sim-media-duo {
    display: flex;
    flex-direction: row;
    align-items: stretch;
  }

  .media-duo-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
  }

  .media-duo-item + .media-duo-item {
    border-left: 2px solid rgba(255,255,255,0.12);
  }

  .media-duo-item img,
  .media-duo-item video {
    flex: 1;
    width: 100%; height: 100%;
    object-fit: cover;
    border: none; box-shadow: none; display: block;
  }

  .media-duo-label {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: rgba(0,0,0,0.72);
    color: var(--color-accent);
    font-family: var(--font-heading);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-align: center;
    padding: 0.3rem 0;
  }

  /* Info panel */
  .sim-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: 1.5rem 1.75rem;
    background: var(--color-bg);
    color: var(--color-text);
    overflow-y: auto;
  }

  .sim-index-label {
    font-family: var(--font-heading);
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.32;
    margin-bottom: 0.3rem;
  }

  .sim-scenario-tag {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--color-dark);
    color: var(--color-bg);
    padding: 0.2rem 0.6rem;
    margin-bottom: 0.6rem;
    align-self: flex-start;
  }

  .mta-tag { background: #003DA5; }

  .sim-info h4 {
    margin: 0 0 1rem 0;
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-dark);
    line-height: 1.2;
    border-bottom: 3px solid var(--color-accent);
    padding-bottom: 0.6rem;
  }

  .sim-finding-block { display: flex; flex-direction: column; gap: 0.85rem; }

  .sim-field { display: flex; flex-direction: column; gap: 0.2rem; }

  .sim-field-label {
    font-family: var(--font-heading);
    font-size: 0.64rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-dark);
    opacity: 0.42;
  }

  .sim-field.finding .sim-field-label {
    color: var(--color-accent, #f68c34);
    opacity: 1;
  }

  .sim-field p { margin: 0; font-size: 0.88rem; line-height: 1.55; color: var(--color-dark); }
  .sim-field p strong { color: var(--color-dark); }

  .sim-bullets {
    margin: 0.25rem 0 0.5rem 1rem;
    padding: 0;
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--color-dark);
  }
  .sim-bullets li { margin-bottom: 0.35rem; }

  .source-field .sim-field-label { opacity: 0.32; }
  .source-field p { font-size: 0.74rem; }
  .source-field a { color: var(--color-accent); text-decoration: underline; word-break: break-word; }

  /* Nav bar */
  .sim-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    padding: 0.55rem 0;
    background: var(--color-dark);
    border-top: 2px solid rgba(255,255,255,0.08);
    flex-shrink: 0;
  }

  .sim-nav-btn {
    background: transparent;
    border: 2px solid rgba(255,255,255,0.35);
    color: var(--color-bg);
    width: 2rem; height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: var(--font-heading);
    line-height: 1;
  }

  .sim-nav-btn:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-text);
    transform: translate(-2px, -2px);
    box-shadow: 2px 2px 0 var(--color-bg);
  }

  .sim-dots { display: flex; gap: 0.5rem; align-items: center; }

  .sim-dot {
    width: 8px; height: 8px;
    border-radius: 0;
    background: rgba(255,255,255,0.25);
    transition: background 0.25s ease, transform 0.25s ease;
    display: block;
    cursor: pointer;
  }

  .sim-dot.active { background: var(--color-accent); transform: scale(1.3); }

  /* ── PATH LAYER ── */
  .interactive-path-layer {
    position: absolute;
    width: 100%; height: 100%;
    display: flex;
    align-items: center;
    background: #222;
  }

  .map-wrapper {
    flex: 1;
    position: relative;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .path-legend {
    width: 320px;
    background: rgba(0,0,0,0.85);
    padding: 1.5rem;
    color: var(--color-bg);
    z-index: 10;
    margin-left: 2rem;
    flex-shrink: 0;
  }

  .path-legend h4 {
    color: var(--color-secondary);
    margin-bottom: 1rem;
    border-bottom: 2px solid var(--color-secondary);
    padding-bottom: 0.5rem;
  }

  .legend-item { display: flex; gap: 1rem; margin-bottom: 1rem; align-items: flex-start; }
  .legend-item:last-child { margin-bottom: 0; }

  .color-swatch {
    width: 16px; height: 16px;
    display: inline-block;
    flex-shrink: 0;
    margin-top: 4px;
    border: 2px solid var(--color-bg);
  }

  .legend-text { font-size: 0.85rem; line-height: 1.3; }
  .legend-text strong { display: block; font-size: 1rem; margin-bottom: 0.2rem; font-family: var(--font-heading); letter-spacing: 0.5px; }
  .legend-text p { margin: 0; font-family: var(--font-body); opacity: 0.9; }

  .base-map-img { width: 100%; height: 100%; object-fit: contain; border: none; box-shadow: none; }
  .path-svg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: auto; }

  .animated-path {
    stroke-dasharray: 4000;
    stroke-dashoffset: 4000;
    animation: draw 3s ease forwards;
  }

  @keyframes draw { to { stroke-dashoffset: 0; } }

  /* ── CONGESTION RELIEF TAB ── */
  .congestion-layer {
    overflow-y: auto;
    background: var(--color-dark);
    display: block;
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
  }

  .cong-hero {
    position: relative;
    width: 100%;
    height: 180px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .cong-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
    border: none;
    box-shadow: none;
  }

  .cong-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(0,0,0,0.75) 40%, rgba(0,0,0,0.2));
    display: flex;
    align-items: center;
    padding: 1.5rem 2rem;
  }

  .cong-hero-text {
    color: #fff;
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    line-height: 1.2;
    max-width: 600px;
    margin: 0;
  }

  .cong-hero-text span {
    color: var(--color-accent);
  }

  .cong-body {
    padding: 1.25rem 2rem 1.5rem;
    display: flex;
